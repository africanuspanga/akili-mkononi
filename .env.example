# MobiShastra SMS Gateway
MOBISHASTRA_USER=DRIFTMARK
MOBISHASTRA_PWD=your_password_here
MOBISHASTRA_SENDER_ID=AKILI

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (optional for MVP - uses in-memory store if not set)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Set to "true" to skip actual SMS sending (logs to console instead)
DRY_RUN=true

# Optional: if set, requires inbound webhook URLs to include ?secret=<value>.
# Gives MobiShastra a URL like /api/webhook/sms?secret=XYZ — anyone without
# the secret gets 401. Leave unset to disable the check (e.g. for local dev).
# WEBHOOK_SECRET=
